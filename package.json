{
  "name": "agentity-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev:frontend": "npm run dev --workspace apps/frontend",
    "dev:backend": "npm run dev --workspace apps/backend",
    "build:frontend": "npm run build --workspace apps/frontend",
    "preview:frontend": "npm run preview --workspace apps/frontend",
    "lint:frontend": "npm run lint --workspace apps/frontend",
    "start:backend": "npm run start --workspace apps/backend",
    "test:backend": "npm run test --workspace apps/backend",
    "smoke:backend": "npm run smoke --workspace apps/backend",
    "db:check": "npm run db:check --workspace apps/backend"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}